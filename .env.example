# Smart Home AI Agent - Environment Configuration Template
# Copy this file to .env and fill in your actual values

# ===== MQTT Configuration =====
# Broker address and port
MQTT_BROKER=localhost
MQTT_PORT=1883
MQTT_USERNAME=
MQTT_PASSWORD=

# ===== Flask Backend Configuration =====
# Server host and port
FLASK_HOST=127.0.0.1
FLASK_PORT=5000
FLASK_DEBUG=True
API_TIMEOUT=10

# ===== Streamlit Frontend Configuration =====
STREAMLIT_THEME=light
STREAMLIT_LAYOUT=wide



# Deepseek API Key (alternative to OpenAI)
# Get from: https://api.deepseek.com
DEEPSEEK_API_KEY=sk-6af297e9d8694a0eb6686da6d51cfd3e
DEEPSEEK_BASE_URL=https://api.deepseek.com

# OpenWeather API Key (for weather data)
# Get from: https://openweathermap.org/api
OPENWEATHER_API_KEY=7e4dc7e538fc1fa0daf70f94def761f1

# ===== Kaggle Configuration =====
# For downloading datasets from Kaggle
# Setup: https://github.com/Kaggle/kaggle-api
# Creates ~/.kaggle/kaggle.json
KAGGLE_USERNAME=jorarrsr
KAGGLE_KEY=KGAT_e07082605249e12838b33f93f4e25a4f

# ===== Forecasting Configuration =====
# Number of hours to forecast ahead
FORECAST_PERIODS=24

# Forecasting model: 'prophet' or 'lstm'
FORECAST_MODEL=prophet

# Energy thresholds in watts
MIN_ENERGY_THRESHOLD=500
MAX_ENERGY_THRESHOLD=5000

# ===== Smart Home Agent Configuration =====
# Enable occupancy-based automation
OCCUPANCY_DETECTION=True

# Enable weather-aware adjustments
WEATHER_AWARE=True

# Enable autonomous optimization
AUTO_OPTIMIZATION=True

# Agent decision interval in seconds
AGENT_DECISION_INTERVAL=300

# Rules engine mode: 'rule-based' or 'hybrid' (rule + LLM)
AGENT_RULES_ENGINE=hybrid

# ===== Peak Hours Configuration =====
# Peak hours start and end (24-hour format)
PEAK_HOURS_START=17
PEAK_HOURS_END=21

# Target load reduction during peak hours (0.0-1.0)
PEAK_HOURS_REDUCTION=0.20

# ===== Logging Configuration =====
# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Log file path
LOG_FILE=logs/smart_home_agent.log

# ===== Database Configuration (Optional) =====
# For storing decision history and analytics
# DATABASE_URL=postgresql://user:password@localhost:5432/smart_home
# DATABASE_ECHO=False

# ===== Monitoring Configuration (Optional) =====
# Enable Prometheus metrics
# PROMETHEUS_ENABLED=False
# PROMETHEUS_PORT=9090

# ===== Security (Production) =====
# API key for backend authentication
# API_SECRET_KEY=your-secret-key-here

# CORS allowed origins
CORS_ORIGINS=http://localhost:8501,http://localhost:3000

# ===== Development Settings =====
# Set to True only in development
DEBUG=True

# Enable verbose logging
VERBOSE=False
